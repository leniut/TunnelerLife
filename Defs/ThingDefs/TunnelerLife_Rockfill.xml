<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef Name="TunnelerLife_RockfillBase" ParentName="BuildingBase" Abstract="True">
    <label>rockfill</label>
    <description>Rebuilds a mined-out tunnel cell into natural rough stone using one matching stone chunk.</description>
    <thingClass>TunnelerLife.Building_Rockfill</thingClass>
    <category>Building</category>
    <uiIconPath>UI/Designators/Rockfill</uiIconPath>
    <altitudeLayer>Building</altitudeLayer>
    <passability>Impassable</passability>
    <fillPercent>1</fillPercent>
    <blockWind>true</blockWind>
    <castEdgeShadows>true</castEdgeShadows>
    <selectable>true</selectable>
    <useHitPoints>true</useHitPoints>
    <holdsRoof>true</holdsRoof>
    <statBases>
      <MaxHitPoints>300</MaxHitPoints>
      <WorkToBuild>800</WorkToBuild>
      <Flammability>0</Flammability>
    </statBases>
    <graphicData>
      <texPath>Things/Building/Linked/Wall</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1,1)</drawSize>
    </graphicData>
    <constructEffect>ConstructMetal</constructEffect>
    <designationHotKey>Misc1</designationHotKey>
    <placeWorkers>
      <li>TunnelerLife.PlaceWorker_Rockfill</li>
    </placeWorkers>
    <building>
      <isInert>true</isInert>
      <isEdifice>true</isEdifice>
      <claimable>false</claimable>
      <ai_chillDestination>false</ai_chillDestination>
      <deconstructible>true</deconstructible>
    </building>
  </ThingDef>

  <ThingDef ParentName="TunnelerLife_RockfillBase">
    <defName>TunnelerLife_Rockfill_Granite</defName>
    <label>granite rockfill</label>
    <costList>
      <ChunkGranite>1</ChunkGranite>
    </costList>
  </ThingDef>

  <ThingDef ParentName="TunnelerLife_RockfillBase">
    <defName>TunnelerLife_Rockfill_Limestone</defName>
    <label>limestone rockfill</label>
    <costList>
      <ChunkLimestone>1</ChunkLimestone>
    </costList>
  </ThingDef>

  <ThingDef ParentName="TunnelerLife_RockfillBase">
    <defName>TunnelerLife_Rockfill_Marble</defName>
    <label>marble rockfill</label>
    <costList>
      <ChunkMarble>1</ChunkMarble>
    </costList>
  </ThingDef>

  <ThingDef ParentName="TunnelerLife_RockfillBase">
    <defName>TunnelerLife_Rockfill_Sandstone</defName>
    <label>sandstone rockfill</label>
    <costList>
      <ChunkSandstone>1</ChunkSandstone>
    </costList>
  </ThingDef>

  <ThingDef ParentName="TunnelerLife_RockfillBase">
    <defName>TunnelerLife_Rockfill_Slate</defName>
    <label>slate rockfill</label>
    <costList>
      <ChunkSlate>1</ChunkSlate>
    </costList>
  </ThingDef>
</Defs>
