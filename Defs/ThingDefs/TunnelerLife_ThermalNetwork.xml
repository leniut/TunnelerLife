<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="BuildingBase" Name="TunnelerLife_ThermalPipe">
    <defName>TunnelerLife_ThermalPipe</defName>
    <label>thermal pipe</label>
    <description>A low-profile pipe that links thermal vents into a passive remote ventilation network. It does not create heat or cold.</description>
    <thingClass>TunnelerLife.Building_ThermalPipe</thingClass>
    <category>Building</category>
    <designationCategory>TunnelerLife</designationCategory>
    <uiOrder>200</uiOrder>
    <graphicData>
      <texPath>Things/Building/Linked/PowerConduit_MenuIcon</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <uiIconPath>Things/Building/Linked/PowerConduit_MenuIcon</uiIconPath>
    <uiIconScale>0.7</uiIconScale>
    <building>
      <ai_chillDestination>false</ai_chillDestination>
      <isInert>true</isInert>
      <isEdifice>false</isEdifice>
      <canLandGravshipOn>true</canLandGravshipOn>
      <blueprintGraphicData>
        <texPath>Things/Building/Linked/PowerConduit_Blueprint_Atlas</texPath>
      </blueprintGraphicData>
      <canConstructInCorner>true</canConstructInCorner>
    </building>
    <drawerType>MapMeshOnly</drawerType>
    <altitudeLayer>Conduits</altitudeLayer>
    <passability>Standable</passability>
    <leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
    <resourcesFractionWhenDeconstructed>0</resourcesFractionWhenDeconstructed>
    <statBases>
      <MaxHitPoints>80</MaxHitPoints>
      <WorkToBuild>35</WorkToBuild>
      <Flammability>0.7</Flammability>
      <Beauty>-1</Beauty>
    </statBases>
    <drawStyleCategory>Conduits</drawStyleCategory>
    <costList>
      <Steel>2</Steel>
    </costList>
    <comps>
      <li Class="TunnelerLife.CompProperties_ThermalPipeOverlay" />
    </comps>
    <placeWorkers>
      <li>TunnelerLife.PlaceWorker_ThermalPipe</li>
    </placeWorkers>
    <rotatable>false</rotatable>
    <selectable>true</selectable>
    <neverMultiSelect>true</neverMultiSelect>
    <soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
    <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
    <constructEffect>ConstructMetal</constructEffect>
    <clearBuildingArea>false</clearBuildingArea>
    <designationHotKey>Misc2</designationHotKey>
    <researchPrerequisites>
      <li>ComplexFurniture</li>
    </researchPrerequisites>
  </ThingDef>

  <ThingDef ParentName="TunnelerLife_ThermalPipe">
    <defName>TunnelerLife_HiddenThermalPipe</defName>
    <label>hidden thermal pipe</label>
    <description>Hidden insulated pipe for linking thermal vents. It is tougher and harder to damage than regular thermal pipe, but slower to build and more expensive.</description>
    <graphicData>
      <color>(0,0,0,0)</color>
      <shaderType>Transparent</shaderType>
    </graphicData>
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <WorkToBuild>280</WorkToBuild>
      <Flammability>0</Flammability>
      <Beauty>0</Beauty>
    </statBases>
    <uiIconPath>Things/Building/Linked/HiddenConduit_MenuIcon</uiIconPath>
    <designationHotKey>Misc9</designationHotKey>
    <costList>
      <Steel>3</Steel>
    </costList>
    <constructEffect>ConstructDirt</constructEffect>
    <building>
      <ai_neverTrashThis>true</ai_neverTrashThis>
      <isTargetable>false</isTargetable>
      <expandHomeArea>false</expandHomeArea>
      <canBeDamagedByAttacks>false</canBeDamagedByAttacks>
    </building>
  </ThingDef>

  <ThingDef ParentName="TunnelerLife_ThermalPipe">
    <defName>TunnelerLife_WaterproofThermalPipe</defName>
    <label>waterproof thermal pipe</label>
    <description>Insulated thermal pipe for linking thermal vents through shallow water or mud.</description>
    <graphicData>
      <texPath>Things/Building/Linked/WaterproofConduit_Atlas</texPath>
    </graphicData>
    <uiIconPath>Things/Building/Linked/WaterproofConduit_MenuIcon</uiIconPath>
    <terrainAffordanceNeeded>WaterproofConduitable</terrainAffordanceNeeded>
    <designationHotKey>Misc8</designationHotKey>
    <costList>
      <Steel>11</Steel>
    </costList>
  </ThingDef>

  <ThingDef ParentName="BuildingBase">
    <defName>TunnelerLife_ThermalVent</defName>
    <label>thermal vent</label>
    <description>A wall vent that connects one room to a thermal pipe network. Open thermal vents in the same network passively equalize room temperatures over distance.</description>
    <thingClass>TunnelerLife.Building_ThermalVent</thingClass>
    <category>Building</category>
    <designationCategory>TunnelerLife</designationCategory>
    <uiOrder>210</uiOrder>
    <graphicData>
      <texPath>Things/Building/Misc/TempControl/Vent</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <damageData>
        <cornerTL>Damage/Corner</cornerTL>
        <cornerTR>Damage/Corner</cornerTR>
        <cornerBL>Damage/Corner</cornerBL>
        <cornerBR>Damage/Corner</cornerBR>
      </damageData>
    </graphicData>
    <altitudeLayer>Building</altitudeLayer>
    <passability>Impassable</passability>
    <blockWind>true</blockWind>
    <fillPercent>1</fillPercent>
    <coversFloor>true</coversFloor>
    <blockLight>true</blockLight>
    <blockWeather>true</blockWeather>
    <castEdgeShadows>true</castEdgeShadows>
    <canOverlapZones>false</canOverlapZones>
    <staticSunShadowHeight>1.0</staticSunShadowHeight>
    <statBases>
      <WorkToBuild>400</WorkToBuild>
      <MaxHitPoints>100</MaxHitPoints>
      <Flammability>1.0</Flammability>
    </statBases>
    <tickerType>Rare</tickerType>
    <costList>
      <Steel>30</Steel>
    </costList>
    <terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
    <placeWorkers>
      <li>TunnelerLife.PlaceWorker_ThermalVent</li>
    </placeWorkers>
    <drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
    <building>
      <canPlaceOverWall>true</canPlaceOverWall>
      <canExchangeVacuum>true</canExchangeVacuum>
      <isAirtight>true</isAirtight>
    </building>
    <researchPrerequisites>
      <li>ComplexFurniture</li>
    </researchPrerequisites>
    <designationHotKey>Misc3</designationHotKey>
    <comps>
      <li Class="CompProperties_Flickable">
        <commandTexture>UI/Commands/Vent</commandTexture>
        <commandLabelKey>CommandDesignateOpenCloseVentLabel</commandLabelKey>
        <commandDescKey>CommandDesignateOpenCloseVentDesc</commandDescKey>
      </li>
    </comps>
  </ThingDef>
</Defs>
